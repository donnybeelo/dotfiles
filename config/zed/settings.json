// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
 "format_on_save": "off",
 "cli_default_open_behavior": "new_window",
 "outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"project_panel": {
		"dock": "left",
	},
	"edit_predictions": {
		"ollama": {
   "max_output_tokens": 64,
   "model": "gemma4:12b"
  },
  "provider": "copilot",
	},
	"git_panel": {
		"dock": "left",
		"tree_view": true,
		"sort_by_path": false,
	},
	"agent_ui_font_size": 16.0,
	"ui_font_family": ".ZedSans",
	"tabs": {
		"git_status": true,
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"terminal": {
		"font_size": 12.0,
		"max_scroll_history_lines": 1000000,
	},
	"language_models": {
	  "ollama": {
	    "available_models": [
	      {
	        "name": "lfm2.5:latest",
	        "max_tokens": 32768,
	        "keep_alive": "1m",
	        "supports_tools": true,
	      },
				{
	        "name": "gemma4:12b",
	        "max_tokens": 32768,
	        "keep_alive": "1m",
	        "supports_tools": true,
	      },
	    ],
	  },
	},
	"agent": {

		"favorite_models": [
   {
    "provider": "ollama",
    "model": "gemma4:latest",
    "enable_thinking": true
   },
   {
    "provider": "ollama",
    "model": "gemma4:26b",
    "enable_thinking": true
   },
   {
    "provider": "ollama",
    "model": "glm4:latest",
    "enable_thinking": false
   },
   {
    "provider": "ollama",
    "model": "lfm2.5:latest"
   }
  ],
  "default_profile": "write",
  "dock": "right",
		"sidebar_side": "left",
		"inline_assistant_model": {
			"provider": "copilot_chat",
			"model": "gemini-3.1-pro-preview",
			"enable_thinking": false,
		},
		"default_model": {
			"enable_thinking": true,
			"provider": "ollama",
			"model": "lfm2.5:latest",
		},
		"tool_permissions": {
			"default": "allow",
		},
	},
	"scroll_sensitivity": 1.0,
	"autosave": {
		"after_delay": {
			"milliseconds": 1000,
		},
	},
	"buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", "monospace"],
	"buffer_font_family": "Fira Code",
	"file_types": {
		"netlogo": ["*.nlogo"],
	},
	"show_edit_predictions": true,
	"hard_tabs": true,
	"base_keymap": "VSCode",
	"icon_theme": {
		"mode": "system",
		"light": "Zed (Default)",
		"dark": "Zed (Default)",
	},
	"ui_font_size": 16,
	"buffer_font_size": 12.0,
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "Carbonfox - opaque",
	},
	"agent_servers": {
		"claude-acp": {
   "default_config_options": {
    "mode": "auto"
   },
   "type": "registry"
  },
  "github-copilot-cli": {
   "default_config_options": {
    "allow_all": "on",
    "model": "auto"
   },
   "type": "registry"
  },
  "pi-acp": {
			"favorite_models": [
    "ollama/lfm2.5:latest"
   ],
   "default_mode": "low",
   "default_model": "ollama/lfm2.5:latest",
   "type": "registry",
		},
		"opencode": {
			"favorite_config_option_values": {
				"model": ["github-copilot/gpt-5.4-mini/medium"],
			},
			"type": "registry",
		},
	},
	"languages": {
		"CSS": {
			"language_servers": ["tailwindcss-language-server"],
		},
		"YAML": {
			"hard_tabs": false,
		},
	},
}
