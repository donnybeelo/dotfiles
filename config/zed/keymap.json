[
	{
		"bindings": {
			"ctrl-alt-i": "workspace::ToggleRightDock",
			"ctrl-r": "projects::OpenRecent",
			"ctrl-alt-f": ["task::Spawn", { "task_name": "Open Nautilus" }]
		}
	},
	{
		"context": "(Workspace || Pane)",
		"bindings": {
			"ctrl-alt-g": ["task::Spawn", { "task_name": "Open SourceGit" }],
			"ctrl-alt-t": [
				"task::Spawn",
				{
					"task_name": "Open Terminal"
				}
			]
		}
	},
	{
		"context": "(Editor && (edit_prediction && (showing_completions || in_leading_whitespace)))",
		"bindings": {
			"tab": "editor::AcceptEditPrediction"
		}
	},
	{
		"context": "(Editor && extension == mdx)",
		"bindings": {
			"ctrl-shift-v": "markdown::OpenPreview"
		}
	},
	{
		"context": "!ContextEditor > (Editor && mode == full)",
		"bindings": {
			"ctrl-i": "assistant::InlineAssist"
		}
	},
	{
		"context": "!ContextEditor > (Editor && mode == full)",
		"bindings": {
			"ctrl-enter": null
		}
	},
 {
  "context": "Editor && edit_prediction",
  "bindings": {
   "alt-right": "editor::AcceptNextWordEditPrediction"
  }
 },
 {
  "context": "Editor && edit_prediction",
  "unbind": {
   "alt-k": "editor::AcceptNextWordEditPrediction"
  }
 },
 {
  "context": "CommitEditor",
  "bindings": {
   "alt-c": [
    "task::Spawn",
    {
     "task_name": "Generate commit message from diff"
    }
   ]
  }
 },
]
